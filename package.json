{
  "name": "webseite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,html}\"",
    "preview": "vite preview",
    "test": "playwright test -c playwright-ct.config.ts",
    "test:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:debug": "playwright test -c playwright-ct.config.ts --debug"
  },
  "dependencies": {
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.185.0",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/experimental-ct-react": "^1.61.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.1.0"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  }
}
